# Copy this file to .env for local testing.
# Do not commit your real .env file.

# This must be the full path to the downloaded service account JSON file.
# Example:
# GOOGLE_APPLICATION_CREDENTIALS=C:\Users\You\Downloads\service-account.json
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# These are only needed locally if you want to send/check Gmail from your machine.
# They are generated by scripts/generate_gmail_token.py.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
